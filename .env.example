# Event Landing — Environment Variables
# Copy to .env and fill in values

# Supabase (for registration form, speakers, schedule)
PUBLIC_SUPABASE_URL=http://localhost:54321
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Registration form endpoint (if using a backend API)
# PUBLIC_REGISTRATION_API_URL=https://api.example.com/register

# Optional: Analytics
# PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Optional: Site URL (used for OG tags / canonical links)
# PUBLIC_SITE_URL=https://devconf2026.example.com

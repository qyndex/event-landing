---
const speakers = [
  { name: "Dr. Ada Lovelace", title: "Keynote: The Future of Computing", avatar: "/avatars/ada.jpg" },
  { name: "Linus T.", title: "Open Source at Scale", avatar: "/avatars/linus.jpg" },
  { name: "Grace Hopper", title: "Debugging the Impossible", avatar: "/avatars/grace.jpg" },
];
---
<section class="py-16 px-4">
  <h2 class="text-3xl font-bold text-center mb-10">Speakers</h2>
  <div class="max-w-4xl mx-auto grid md:grid-cols-3 gap-8">
    {speakers.map((s) => (
      <div class="text-center">
        <img src={s.avatar} alt={s.name} class="w-24 h-24 rounded-full mx-auto mb-3" />
        <h3 class="font-semibold text-lg">{s.name}</h3>
        <p class="text-sm opacity-75">{s.title}</p>
      </div>
    ))}
  </div>
</section>

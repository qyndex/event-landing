---
import Countdown from "../components/Countdown.astro";
import Speakers from "../components/Speakers.astro";
import Schedule from "../components/Schedule.astro";
import Sponsors from "../components/Sponsors.astro";
import RegistrationForm from "../components/RegistrationForm.astro";
import { fetchSpeakers, fetchSchedule, fetchSponsors } from "../lib/schedule";

const speakers = await fetchSpeakers();
const schedule = await fetchSchedule();
const sponsors = await fetchSponsors();
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>DevConf 2026 — The Developer Conference</title>
  <meta name="description" content="DevConf 2026: Two days of talks, workshops, and networking with the best minds in software. June 15-16, San Francisco." />
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><text y='28' font-size='28'>🎤</text></svg>" />
</head>
<body class="bg-gray-950 text-gray-100 font-sans antialiased">

  <!-- Navigation -->
  <nav class="fixed top-0 w-full z-50 bg-gray-950/80 backdrop-blur-md border-b border-gray-800">
    <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
      <a href="#" class="text-lg font-bold tracking-tight">
        <span class="text-blue-400">Dev</span>Conf<span class="text-gray-500">2026</span>
      </a>
      <div class="hidden md:flex items-center gap-8 text-sm">
        <a href="#speakers" class="hover:text-blue-400 transition-colors">Speakers</a>
        <a href="#schedule" class="hover:text-blue-400 transition-colors">Schedule</a>
        <a href="#sponsors" class="hover:text-blue-400 transition-colors">Sponsors</a>
        <a href="#register" class="bg-blue-600 hover:bg-blue-500 text-white px-4 py-2 rounded-lg font-medium transition-colors">
          Register Now
        </a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <header class="relative pt-32 pb-20 px-4 text-center overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-blue-950/30 via-transparent to-transparent"></div>
    <div class="relative z-10 max-w-3xl mx-auto">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-600/10 border border-blue-500/20 text-blue-400 text-sm mb-8">
        <span class="w-2 h-2 rounded-full bg-blue-400 animate-pulse"></span>
        June 15-16, 2026 &middot; San Francisco, CA
      </div>
      <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight leading-tight">
        DevConf <span class="text-blue-400">2026</span>
      </h1>
      <p class="text-xl md:text-2xl text-gray-400 mt-6 max-w-2xl mx-auto leading-relaxed">
        Two days of talks, workshops, and hallway conversations with the builders shaping the future of software.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mt-10">
        <a href="#register" class="bg-blue-600 hover:bg-blue-500 text-white px-8 py-3 rounded-lg text-lg font-semibold transition-colors">
          Get Your Ticket
        </a>
        <a href="#schedule" class="border border-gray-700 hover:border-gray-500 text-gray-300 px-8 py-3 rounded-lg text-lg font-semibold transition-colors">
          View Schedule
        </a>
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-3 gap-8 max-w-md mx-auto mt-16">
        <div>
          <div class="text-3xl font-bold text-white">6</div>
          <div class="text-sm text-gray-500 mt-1">Speakers</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-white">2</div>
          <div class="text-sm text-gray-500 mt-1">Days</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-white">2</div>
          <div class="text-sm text-gray-500 mt-1">Tracks</div>
        </div>
      </div>
    </div>
  </header>

  <!-- Countdown -->
  <Countdown targetDate="2026-06-15T09:00:00Z" />

  <!-- Speakers -->
  <Speakers speakers={speakers} />

  <!-- Schedule -->
  <Schedule days={schedule} />

  <!-- Sponsors -->
  <Sponsors sponsors={sponsors} />

  <!-- Registration -->
  <RegistrationForm />

  <!-- Footer -->
  <footer class="border-t border-gray-800 bg-gray-950 py-12 px-4">
    <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6 text-sm text-gray-500">
      <div>
        <span class="font-semibold text-gray-400">DevConf 2026</span> &middot; June 15-16 &middot; San Francisco, CA
      </div>
      <div class="flex gap-6">
        <a href="#" class="hover:text-gray-300 transition-colors">Code of Conduct</a>
        <a href="#" class="hover:text-gray-300 transition-colors">Privacy Policy</a>
        <a href="#" class="hover:text-gray-300 transition-colors">Contact</a>
      </div>
    </div>
  </footer>

</body>
</html>
